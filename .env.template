# Daily Priority Digest - Environment Configuration
# Copy this file as ".env" in your project folder
# Fill in your actual values below

# Get your Anthropic API key from: https://console.anthropic.com/api/keys
ANTHROPIC_API_KEY=sk-ant-your-actual-key-here

# Your Gmail address (the one with Gmail, Slack, Calendar, Drive connected)
GMAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your regular password)
# Generate here: https://myaccount.google.com/apppasswords
# Steps:
#   1. Go to the link above
#   2. Select "Mail" and your device type
#   3. Click "Generate"
#   4. Copy the 16-character password shown
#   5. Paste below (it includes spaces)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# (Optional) Send digest to a different email address
# If not set, will use GMAIL_USER
# EMAIL_RECIPIENT=different-email@gmail.com

# (Optional) Send to multiple emails (comma-separated)
# EMAIL_RECIPIENT=you@gmail.com,colleague@company.com,manager@company.com

# (Optional) Schedule time in cron format
# Default: "0 7 * * *" (7:00 AM every day)
# 
# Format: minute hour day month dayOfWeek
# Examples:
#   "0 8 * * *" = 8:00 AM every day
#   "30 6 * * *" = 6:30 AM every day
#   "0 9 * * 1-5" = 9:00 AM Monday-Friday only (1=Mon, 5=Fri)
#   "0 12 * * 0" = 12:00 PM Sundays only
#   "0 6,12,18 * * *" = 6am, noon, and 6pm every day
SCHEDULE_TIME=0 7 * * *
